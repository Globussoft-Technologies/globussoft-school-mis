model Stop {
  id               String   @id @default(uuid())
  routeId          String
  name             String
  latitude         Float?
  longitude        Float?
  estimatedArrival String?
  orderIndex       Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  route          Route           @relation(fields: [routeId], references: [id], onDelete: Cascade)
  busAssignments BusAssignment[]
  boardingLogs   BoardingLog[]

  @@map("stops")
}

model BusAssignment {
  id                String   @id @default(uuid())
  studentId         String   @unique
  routeId           String
  stopId            String
  academicSessionId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student         Student         @relation(fields: [studentId], references: [id])
  route           Route           @relation(fields: [routeId], references: [id])
  stop            Stop            @relation(fields: [stopId], references: [id])
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])

  @@map("bus_assignments")
}

model BoardingLog {
  id            String    @id @default(uuid())
  studentId     String
  routeId       String
  stopId        String
  date          DateTime  @db.Date
  boardingTime  DateTime?
  alightingTime DateTime?
  type          String    // MORNING, EVENING
  status        String    @default("ABSENT") // BOARDED, ALIGHTED, ABSENT
  conductorId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student   Student  @relation(fields: [studentId], references: [id])
  route     Route    @relation(fields: [routeId], references: [id])
  stop      Stop     @relation(fields: [stopId], references: [id])
  conductor User?    @relation("BoardingsRecorded", fields: [conductorId], references: [id])

  @@map("boarding_logs")
}

// ─── Teacher Attendance & Leave ──────────────────────────────────

