// ─── Meeting Minutes ───────────────────────────────────────────

model MeetingMinutes {
  id          String   @id @default(uuid())
  title       String
  meetingDate DateTime @db.Date
  startTime   String?
  endTime     String?
  location    String?
  type        String   // STAFF, DEPARTMENT, PTA, COMMITTEE, BOARD, OTHER
  attendees   Json     @default("[]")  // [{userId, name, role}]
  agenda      Json     @default("[]")  // [{item, discussion, decision}]
  actionItems Json     @default("[]")  // [{task, assignedTo, dueDate, status}]
