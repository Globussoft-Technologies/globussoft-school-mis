}

// ─── Room Booking ──────────────────────────────────────────────

model SchoolRoom {
  id          String   @id @default(uuid())
  name        String
  type        String   // CLASSROOM, LAB, AUDITORIUM, CONFERENCE, SPORTS_HALL, LIBRARY, OTHER
  capacity    Int
  floor       Int?
  building    String?
  hasProjector Boolean @default(false)
  hasAC       Boolean @default(false)
  isActive    Boolean @default(true)
  schoolId    String
  createdAt   DateTime @default(now())

