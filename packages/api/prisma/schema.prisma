}

model RoomBooking {
  id          String   @id @default(uuid())
  roomId      String
  bookedBy    String   // userId
  date        DateTime @db.Date
  startTime   String   // HH:mm
  endTime     String   // HH:mm
  purpose     String
  status      String   @default("CONFIRMED") // PENDING, CONFIRMED, CANCELLED
  attendees   Int?
  remarks     String?
  createdAt   DateTime @default(now())

