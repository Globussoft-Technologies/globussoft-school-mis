  recordedBy  String   // userId
  status      String   @default("DRAFT") // DRAFT, CIRCULATED, APPROVED
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("meeting_minutes")
}

// ─── Activity Log ─────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(uuid())
  studentId   String
  type        String   // ENROLLMENT, ATTENDANCE, GRADE, ASSESSMENT, INCIDENT, LEAVE, HOBBY, AWARD, HEALTH, PROMOTION, TRANSFER, OTHER
  title       String
  description String?
  metadata    Json?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([studentId, date])
  @@map("activity_logs")
}

// ─── Hostel / Boarding ────────────────────────────────────────────

model HostelRoom {
  id         String   @id @default(uuid())
  roomNumber String
  floor      Int
  block      String   // A, B, C
  capacity   Int      @default(4)
  occupied   Int      @default(0)
  type       String   @default("SHARED") // SINGLE, SHARED, DORMITORY
  amenities  Json     @default("[]")
  isActive   Boolean  @default(true)
  schoolId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  allocations HostelAllocation[]

  @@unique([roomNumber, block, schoolId])
  @@map("hostel_rooms")
}

model HostelAllocation {
  id        String    @id @default(uuid())
  studentId String
  roomId    String
  bedNumber Int?
  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date
  status    String    @default("ACTIVE") // ACTIVE, VACATED, TRANSFERRED
  createdAt DateTime  @default(now())

  room HostelRoom @relation(fields: [roomId], references: [id])

  @@map("hostel_allocations")
}

model HostelFee {
  id        String    @id @default(uuid())
  studentId String
  month     Int
  year      Int
  amount    Float
  status    String    @default("PENDING") // PENDING, PAID, WAIVED
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([studentId, month, year])
  @@map("hostel_fees")
}

// ─── Payroll ──────────────────────────────────────────────────────

model PayrollRecord {
  id          String    @id @default(uuid())
  userId      String
  month       Int
  year        Int
  basicSalary Float
  allowances  Float     @default(0)
  deductions  Float     @default(0)
