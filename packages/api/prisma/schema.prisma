  overallPercentage Float?
  remarks           String?
  processedBy       String?
  processedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@unique([studentId, academicSessionId])
  @@map("promotions")
}

// ─── Announcements / Circulars ───────────────────────────────────

model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
