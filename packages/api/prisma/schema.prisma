generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Core ────────────────────────────────────────────────────────

model School {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  academicSessions AcademicSession[]
  classes          Class[]
  hobbies          Hobby[]
  conversations    Conversation[]
  vehicles         Vehicle[]
  routes           Route[]

  @@map("schools")
}

model AcademicSession {
  id        String   @id @default(uuid())
  name      String   // e.g. "2026-27"
  startDate DateTime
  endDate   DateTime
  status    String   @default("UPCOMING") // UPCOMING, ACTIVE, COMPLETED
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school           School            @relation(fields: [schoolId], references: [id])
  students         Student[]
  syllabi          Syllabus[]
  timetables       Timetable[]
  assessments      Assessment[]
  reportCards      ReportCard[]
  hobbyEnrollments HobbyEnrollment[]
  ptmSlots         PTMSlot[]
  feeHeads         FeeHead[]
  feeStructures    FeeStructure[]
  busAssignments   BusAssignment[]

  @@map("academic_sessions")
}

// ─── Auth & Users ────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         String   // enum enforced at app level
  avatarUrl    String?
  isActive     Boolean  @default(true)
  schoolId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school                School               @relation(fields: [schoolId], references: [id])
  student               Student?
  teacherSubjects       TeacherSubject[]
  attendancesMarked     Attendance[]         @relation("MarkedBy")
  lessonPlans           LessonPlan[]
  refreshTokens         RefreshToken[]
  lmsContents           LmsContent[]
  assessmentsCreated    Assessment[]         @relation("AssessmentCreator")
  submissions           AssessmentSubmission[]
  gradesGiven           Grade[]              @relation("GradedBy")
  complianceLogs        LessonDelivery[]
  reportCardsIssued     ReportCard[]         @relation("IssuedBy")
  hobbiesCoordinated    Hobby[]              @relation("HobbyCoordinator")
  hobbySessionsConducted HobbySession[]     @relation("SessionConductedBy")
  ptmSlots              PTMSlot[]
  ptmBookings           PTMBooking[]
  messagesSent          Message[]
  notifications         Notification[]
  paymentsReceived      Payment[]            @relation("PaymentsReceived")
  incidentsReported     Incident[]           @relation("IncidentsReported")
  actionsAssigned       DisciplinaryAction[] @relation("ActionsAssigned")
  boardingsRecorded     BoardingLog[]        @relation("BoardingsRecorded")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Academic Structure ──────────────────────────────────────────

model Class {
  id        String   @id @default(uuid())
  name      String   // e.g. "Class 1", "Class 12"
  grade     Int      // numeric grade 1-12
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school         School         @relation(fields: [schoolId], references: [id])
  sections       Section[]
  subjects       Subject[]
  students       Student[]
  syllabi        Syllabus[]
  timetables     Timetable[]
  lmsContents    LmsContent[]
  assessments    Assessment[]
  reportCards    ReportCard[]
  ptmSlots       PTMSlot[]
  feeHeads       FeeHead[]
  feeStructures  FeeStructure[]

  @@unique([grade, schoolId])
  @@map("classes")
}

model Section {
  id        String   @id @default(uuid())
  name      String   // e.g. "A", "B", "C"
  classId   String
  capacity  Int      @default(40)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class      Class       @relation(fields: [classId], references: [id])
  students   Student[]
  timetables Timetable[]

  @@unique([name, classId])
  @@map("sections")
}

model Subject {
  id          String   @id @default(uuid())
  name        String
  code        String
  classId     String
  description String?
  isElective  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class           Class            @relation(fields: [classId], references: [id])
  teachers        TeacherSubject[]
  syllabi         Syllabus[]
  timetableSlots  TimetableSlot[]
  lmsContents     LmsContent[]
  assessments     Assessment[]
  grades          Grade[]
  questionBanks   QuestionBank[]
  assignments     Assignment[]

  @@unique([code, classId])
  @@map("subjects")
}

model TeacherSubject {
  id        String @id @default(uuid())
  teacherId String
  subjectId String

  teacher User    @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

// ─── Students & Admission ────────────────────────────────────────

model Student {
  id                String   @id @default(uuid())
  admissionNo       String   @unique
  userId            String   @unique
  classId           String
  sectionId         String
  rollNo            Int?
  dateOfBirth       DateTime
  gender            String   // MALE, FEMALE, OTHER
  bloodGroup        String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  pincode           String?
  country           String   @default("India")
  isActive          Boolean  @default(true)
  academicSessionId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User                   @relation(fields: [userId], references: [id])
  class             Class                  @relation(fields: [classId], references: [id])
  section           Section                @relation(fields: [sectionId], references: [id])
  academicSession   AcademicSession        @relation(fields: [academicSessionId], references: [id])
  guardians         Guardian[]
  attendances       Attendance[]
  submissions       AssessmentSubmission[]
  grades            Grade[]
  reportCards       ReportCard[]
  hobbyEnrollments  HobbyEnrollment[]
  hobbyAttendances  HobbyAttendance[]
  ptmBookings       PTMBooking[]
  payments          Payment[]
  concessions       Concession[]
  defaulterRecords  DefaulterRecord[]
  incidents         Incident[]
  redFlags          RedFlag[]
  busAssignment     BusAssignment?
  boardingLogs      BoardingLog[]

  @@map("students")
}

model Guardian {
  id         String  @id @default(uuid())
  studentId  String
  relation   String  // FATHER, MOTHER, GUARDIAN
  name       String
  phone      String
  email      String?
  occupation String?
  userId     String? // linked if guardian has a parent account

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("guardians")
}

model AdmissionEnquiry {
  id                String   @id @default(uuid())
  studentName       String
  parentName        String
  parentPhone       String
  parentEmail       String?
  classAppliedFor   String
  status            String   @default("ENQUIRY")
  source            String   // WALK_IN, WEBSITE, REFERRAL, ADVERTISEMENT
  notes             String?
  assignedTo        String?
  academicSessionId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  applications AdmissionApplication[]

  @@map("admission_enquiries")
}

model AdmissionApplication {
  id               String   @id @default(uuid())
  enquiryId        String
  formNumber       String   @unique
  studentFirstName String
  studentLastName  String
  dateOfBirth      DateTime
  gender           String
  classAppliedFor  String
  previousSchool   String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  pincode          String?
  status           String   @default("APPLICATION")
  academicSessionId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  enquiry   AdmissionEnquiry     @relation(fields: [enquiryId], references: [id])
  documents AdmissionDocument[]

  @@map("admission_applications")
}

model AdmissionDocument {
  id            String  @id @default(uuid())
  applicationId String
  type          String  // BIRTH_CERTIFICATE, TRANSFER_CERTIFICATE, etc.
  fileName      String
  fileUrl       String
  verified      Boolean @default(false)

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("admission_documents")
}

// ─── Attendance ──────────────────────────────────────────────────

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  date      DateTime @db.Date
  status    String   // PRESENT, ABSENT, LATE, HALF_DAY, EXCUSED
  markedById String
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student  Student @relation(fields: [studentId], references: [id])
  markedBy User    @relation("MarkedBy", fields: [markedById], references: [id])

  @@unique([studentId, date])
  @@map("attendances")
}

// ─── Syllabus & Lesson Plans ─────────────────────────────────────

model Syllabus {
  id                String    @id @default(uuid())
  subjectId         String
  classId           String
  academicSessionId String
  approvedBy        String?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subject         Subject         @relation(fields: [subjectId], references: [id])
  class           Class           @relation(fields: [classId], references: [id])
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  chapters        Chapter[]

  @@unique([subjectId, classId, academicSessionId])
  @@map("syllabi")
}

model Chapter {
  id             String @id @default(uuid())
  syllabusId     String
  title          String
  description    String?
  orderIndex     Int
  estimatedHours Float  @default(0)

  syllabus   Syllabus     @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  topics     Topic[]
  lessonPlans LessonPlan[]

  @@map("chapters")
}

model Topic {
  id                 String   @id @default(uuid())
  chapterId          String
  title              String
  description        String?
  orderIndex         Int
  learningObjectives Json     @default("[]")
  estimatedMinutes   Int      @default(0)

  chapter      Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  lessonPlans  LessonPlan[]
  lmsContents  LmsContent[]

  @@map("topics")
}

model LessonPlan {
  id            String   @id @default(uuid())
  chapterId     String
  topicId       String
  teacherId     String
  scheduledDate DateTime @db.Date
  objectives    Json     @default("[]")
  methodology   String?
  resources     Json     @default("[]")
  assessment    String?
  status        String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, DELIVERED
  feedback      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chapter    Chapter          @relation(fields: [chapterId], references: [id])
  topic      Topic            @relation(fields: [topicId], references: [id])
  teacher    User             @relation(fields: [teacherId], references: [id])
  deliveries LessonDelivery[]

  @@map("lesson_plans")
}

// ─── Timetable ───────────────────────────────────────────────────

model Timetable {
  id                String    @id @default(uuid())
  classId           String
  sectionId         String
  academicSessionId String
  effectiveFrom     DateTime  @db.Date
  effectiveTo       DateTime? @db.Date
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  class           Class           @relation(fields: [classId], references: [id])
  section         Section         @relation(fields: [sectionId], references: [id])
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  slots           TimetableSlot[]

  @@map("timetables")
}

model TimetableSlot {
  id          String @id @default(uuid())
  timetableId String
  dayOfWeek   Int    // 0=Sun, 1=Mon ... 6=Sat
  startTime   String // HH:mm
  endTime     String // HH:mm
  subjectId   String?
  teacherId   String?
  room        String?
  type        String @default("LECTURE") // LECTURE, LAB, BREAK, ASSEMBLY, FREE

  timetable Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  subject   Subject?  @relation(fields: [subjectId], references: [id])

  @@map("timetable_slots")
}

// ─── LMS Content ─────────────────────────────────────────────────

model LmsContent {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String   // VIDEO, DOCUMENT, PRESENTATION, LINK, AUDIO, INTERACTIVE
  fileUrl     String?
  externalUrl String?
  subjectId   String
  classId     String
  topicId     String?
  uploadedBy  String
  isPublished Boolean  @default(false)
  tags        Json     @default("[]")
  duration    Int?     // minutes for video/audio
  fileSize    Int?     // bytes
  mimeType    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject  Subject @relation(fields: [subjectId], references: [id])
  class    Class   @relation(fields: [classId], references: [id])
  topic    Topic?  @relation(fields: [topicId], references: [id])
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@map("lms_contents")
}

// ─── Homework & Assignments ───────────────────────────────────────

model Assignment {
  id                String    @id @default(uuid())
  title             String
  instructions      String?   @db.Text
  type              String    // FILE_SUBMISSION, TEXT_RESPONSE, ONLINE_QUIZ, DRAWING
  subjectId         String
  classId           String
  sectionId         String?
  teacherId         String
  dueDate           DateTime
  totalMarks        Float
  isPublished       Boolean   @default(false)
  allowLate         Boolean   @default(false)
  latePenalty       Float?    // percentage deduction
  attachmentUrl     String?
  academicSessionId String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subject     Subject                @relation(fields: [subjectId], references: [id])
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String    @id @default(uuid())
  assignmentId String
  studentId    String
  content      String?   @db.Text
  fileUrl      String?
  submittedAt  DateTime  @default(now())
  isLate       Boolean   @default(false)
  marksAwarded Float?
  feedback     String?   @db.Text
  status       String    @default("SUBMITTED") // SUBMITTED, GRADED, RETURNED, RESUBMIT
  gradedAt     DateTime?
  gradedBy     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

// ─── Lesson Delivery & Compliance ────────────────────────────────

model LessonDelivery {
  id            String    @id @default(uuid())
  lessonPlanId  String
  teacherId     String
  deliveredAt   DateTime
  duration      Int       // actual minutes
  topicsCovered Json      @default("[]")
  methodology   String?
  studentCount  Int?
  remarks       String?
  attachments   Json      @default("[]")
  status        String    @default("COMPLETED") // COMPLETED, PARTIAL, CANCELLED
  rating        Int?      // 1-5 self-rating
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lessonPlan LessonPlan @relation(fields: [lessonPlanId], references: [id])
  teacher    User       @relation(fields: [teacherId], references: [id])

  @@map("lesson_deliveries")
}

// ─── Question Bank ───────────────────────────────────────────────

model QuestionBank {
  id        String   @id @default(uuid())
  subjectId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject   Subject    @relation(fields: [subjectId], references: [id])
  questions Question[]

  @@map("question_banks")
}

model Question {
  id             String   @id @default(uuid())
  bankId         String
  type           String   // MCQ, SHORT_ANSWER, LONG_ANSWER, TRUE_FALSE, FILL_BLANK, MATCH, ASSERTION_REASON, CASE_STUDY
  text           String
  options        Json?    // for MCQ: [{id, text, isCorrect}]
  correctAnswer  String?  // for non-MCQ
  explanation    String?
  marks          Float    @default(1)
  difficultyLevel String  @default("MEDIUM") // EASY, MEDIUM, HARD
  tags           Json     @default("[]")
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bank                QuestionBank           @relation(fields: [bankId], references: [id], onDelete: Cascade)
  assessmentQuestions AssessmentQuestion[]

  @@map("questions")
}

// ─── Assessments (8 Tiers) ───────────────────────────────────────

model Assessment {
  id                String    @id @default(uuid())
  title             String
  type              String    // CLASSWORK, HOMEWORK, QUIZ, UNIT_TEST, MID_TERM, FINAL_EXAM, PRACTICAL, PROJECT
  tier              Int       // 1-8 mapping to type complexity
  subjectId         String
  classId           String
  academicSessionId String
  createdBy         String
  totalMarks        Float
  passingMarks      Float?
  duration          Int?      // minutes
  instructions      String?
  scheduledDate     DateTime? @db.Date
  dueDate           DateTime?
  isPublished       Boolean   @default(false)
  isOnline          Boolean   @default(false)
  allowLateSubmit   Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subject         Subject                @relation(fields: [subjectId], references: [id])
  class           Class                  @relation(fields: [classId], references: [id])
  academicSession AcademicSession        @relation(fields: [academicSessionId], references: [id])
  creator         User                   @relation("AssessmentCreator", fields: [createdBy], references: [id])
  questions       AssessmentQuestion[]
  submissions     AssessmentSubmission[]
  grades          Grade[]

  @@map("assessments")
}

model AssessmentQuestion {
  id           String @id @default(uuid())
  assessmentId String
  questionId   String
  orderIndex   Int
  marks        Float

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
  @@map("assessment_questions")
}

model AssessmentSubmission {
  id           String    @id @default(uuid())
  assessmentId String
  studentId    String
  submittedBy  String    // userId
  answers      Json?     // [{questionId, answer, isCorrect?, marksAwarded?}]
  fileUrl      String?   // for file-based submissions
  submittedAt  DateTime  @default(now())
  totalMarks   Float?
  isLate       Boolean   @default(false)
  status       String    @default("SUBMITTED") // DRAFT, SUBMITTED, GRADED, RETURNED
  feedback     String?
  gradedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  submitter  User       @relation(fields: [submittedBy], references: [id])

  @@unique([assessmentId, studentId])
  @@map("assessment_submissions")
}

// ─── Grading ─────────────────────────────────────────────────────

model Grade {
  id           String   @id @default(uuid())
  studentId    String
  subjectId    String
  assessmentId String?
  type         String   // ASSESSMENT, CLASSWORK, PARTICIPATION, ATTENDANCE_BONUS, EXTRA_CREDIT
  marksObtained Float
  maxMarks     Float
  percentage   Float?
  gradeLabel   String?  // A+, A, B+, B, C, D, F
  gradedBy     String
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student    Student     @relation(fields: [studentId], references: [id])
  subject    Subject     @relation(fields: [subjectId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
  grader     User        @relation("GradedBy", fields: [gradedBy], references: [id])

  @@map("grades")
}

// ─── Report Cards ────────────────────────────────────────────────

model ReportCard {
  id                String   @id @default(uuid())
  studentId         String
  classId           String
  academicSessionId String
  term              String   // TERM_1, TERM_2, ANNUAL
  overallPercentage Float?
  overallGrade      String?
  rank              Int?
  totalStudents     Int?
  teacherRemarks    String?
  principalRemarks  String?
  issuedBy          String?
  issuedAt          DateTime?
  status            String   @default("DRAFT") // DRAFT, GENERATED, APPROVED, PUBLISHED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student         Student          @relation(fields: [studentId], references: [id])
  class           Class            @relation(fields: [classId], references: [id])
  academicSession AcademicSession  @relation(fields: [academicSessionId], references: [id])
  issuer          User?            @relation("IssuedBy", fields: [issuedBy], references: [id])
  subjectResults  SubjectResult[]

  @@unique([studentId, academicSessionId, term])
  @@map("report_cards")
}

model SubjectResult {
  id           String @id @default(uuid())
  reportCardId String
  subjectName  String
  maxMarks     Float
  obtained     Float
  grade        String?
  teacherNote  String?

  reportCard ReportCard @relation(fields: [reportCardId], references: [id], onDelete: Cascade)

  @@map("subject_results")
}

// ─── Hobby & Co-curricular ────────────────────────────────────────

model Hobby {
  id                String   @id @default(uuid())
  name              String
  category          String   // VISUAL_ARTS, PERFORMING_ARTS, SPORTS, TECHNOLOGY, LITERARY, PHOTOGRAPHY
  description       String?
  maxCapacity       Int
  currentEnrollment Int      @default(0)
  coordinatorId     String
  isActive          Boolean  @default(true)
  schoolId          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  coordinator  User              @relation("HobbyCoordinator", fields: [coordinatorId], references: [id])
  school       School            @relation(fields: [schoolId], references: [id])
  enrollments  HobbyEnrollment[]
  sessions     HobbySession[]

  @@map("hobbies")
}

model HobbyEnrollment {
  id                String   @id @default(uuid())
  studentId         String
  hobbyId           String
  academicSessionId String
  status            String   @default("ENROLLED") // ENROLLED, WITHDRAWN, COMPLETED
  enrolledAt        DateTime @default(now())
  level             String   @default("BEGINNER") // BEGINNER, INTERMEDIATE, ADVANCED

  student         Student         @relation(fields: [studentId], references: [id])
  hobby           Hobby           @relation(fields: [hobbyId], references: [id])
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])

  @@unique([studentId, hobbyId, academicSessionId])
  @@map("hobby_enrollments")
}

model HobbySession {
  id          String   @id @default(uuid())
  hobbyId     String
  date        DateTime @db.Date
  startTime   String   // HH:mm
  endTime     String   // HH:mm
  activity    String
  materials   String?
  notes       String?
  conductedBy String
  createdAt   DateTime @default(now())

  hobby       Hobby             @relation(fields: [hobbyId], references: [id])
  conductor   User              @relation("SessionConductedBy", fields: [conductedBy], references: [id])
  attendances HobbyAttendance[]

  @@map("hobby_sessions")
}

model HobbyAttendance {
  id        String  @id @default(uuid())
  sessionId String
  studentId String
  status    String  @default("PRESENT") // PRESENT, ABSENT
  remarks   String?

  session HobbySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@map("hobby_attendances")
}

// ─── Communication & PTM ─────────────────────────────────────────

model PTMSlot {
  id                String   @id @default(uuid())
  date              DateTime @db.Date
  startTime         String   // HH:mm
  endTime           String   // HH:mm
  teacherId         String
  classId           String
  maxBookings       Int
  bookedCount       Int      @default(0)
  academicSessionId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  teacher         User            @relation(fields: [teacherId], references: [id])
  class           Class           @relation(fields: [classId], references: [id])
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  bookings        PTMBooking[]

  @@map("ptm_slots")
}

model PTMBooking {
  id           String    @id @default(uuid())
  slotId       String
  parentId     String
  studentId    String
  status       String    @default("BOOKED") // BOOKED, CANCELLED, COMPLETED
  meetingNotes String?
  actionItems  Json      @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  slot    PTMSlot @relation(fields: [slotId], references: [id])
  parent  User    @relation(fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("ptm_bookings")
}

model Conversation {
  id             String   @id @default(uuid())
  participantIds Json     @default("[]")
  type           String   // PARENT_TEACHER, ANNOUNCEMENT, GROUP
  lastMessageAt  DateTime @default(now())
  schoolId       String
  createdAt      DateTime @default(now())

  school   School    @relation(fields: [schoolId], references: [id])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@map("messages")
}

// ─── Notifications ───────────────────────────────────────────────

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String    // ATTENDANCE, TEST_RESULT, FEE_DUE, HOMEWORK, RED_FLAG, BUS, GENERAL
  channel   String    // PUSH, SMS, WHATSAPP, EMAIL
  status    String    @default("PENDING") // PENDING, SENT, FAILED, READ
  sentAt    DateTime?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}




// === Fee Management ===

model FeeHead {
  id                String   @id @default(uuid())
  name              String
  description       String?
  amount            Float
  classId           String
  academicSessionId String
  isRecurring       Boolean  @default(false)
  frequency         String   @default("ONE_TIME") // MONTHLY, QUARTERLY, ANNUALLY, ONE_TIME
  dueDay            Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  class             Class                 @relation(fields: [classId], references: [id])
  academicSession   AcademicSession       @relation(fields: [academicSessionId], references: [id])
  payments          Payment[]
  concessions       Concession[]
  defaulterRecords  DefaulterRecord[]
  feeStructureLinks FeeStructureFeeHead[]

  @@map("fee_heads")
}

model FeeStructure {
  id                String   @id @default(uuid())
  classId           String
  academicSessionId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  class           Class                 @relation(fields: [classId], references: [id])
  academicSession AcademicSession       @relation(fields: [academicSessionId], references: [id])
  feeHeads        FeeStructureFeeHead[]

  @@unique([classId, academicSessionId])
  @@map("fee_structures")
}

model FeeStructureFeeHead {
  id             String @id @default(uuid())
  feeStructureId String
  feeHeadId      String

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  feeHead      FeeHead      @relation(fields: [feeHeadId], references: [id], onDelete: Cascade)

  @@unique([feeStructureId, feeHeadId])
  @@map("fee_structure_fee_heads")
}

model Payment {
  id            String    @id @default(uuid())
  studentId     String
  feeHeadId     String
  amount        Float
  paidAmount    Float     @default(0)
  discount      Float     @default(0)
  method        String    @default("CASH") // CASH, ONLINE, CHEQUE, UPI
  transactionId String?
  receiptNo     String    @unique
  status        String    @default("PENDING") // PENDING, PAID, PARTIAL, REFUNDED
  paidAt        DateTime?
  receivedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student  Student @relation(fields: [studentId], references: [id])
  feeHead  FeeHead @relation(fields: [feeHeadId], references: [id])
  receiver User?   @relation("PaymentsReceived", fields: [receivedBy], references: [id])

  @@map("payments")
}

model Concession {
  id              String   @id @default(uuid())
  studentId       String
  feeHeadId       String
  type            String   // SCHOLARSHIP, SIBLING, STAFF, MERIT, OTHER
  discountPercent Float?
  discountAmount  Float?
  approvedBy      String?
  reason          String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  feeHead FeeHead @relation(fields: [feeHeadId], references: [id])

  @@map("concessions")
}

model DefaulterRecord {
  id             String    @id @default(uuid())
  studentId      String
  feeHeadId      String
  amountDue      Float
  dueDate        DateTime
  callAttempts   Int       @default(0)
  lastCallAt     DateTime?
  lastCallStatus String?
  smsSent        Int       @default(0)
  escalatedTo    String?
  status         String    @default("ACTIVE") // ACTIVE, RESOLVED, ESCALATED
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  feeHead FeeHead @relation(fields: [feeHeadId], references: [id])

  @@map("defaulter_records")
}

// === Discipline ===

model Incident {
  id          String   @id @default(uuid())
  studentId   String
  reportedBy  String
  date        DateTime @db.Date
  time        String?
  type        String   // MISCONDUCT, BULLYING, PROPERTY_DAMAGE, CHEATING, ALTERCATION, UNIFORM_VIOLATION, MOBILE_USE, OTHER
  severity    String   // MINOR, MODERATE, SERIOUS
  description String
  witnesses   Json     @default("[]")
  location    String?
  status      String   @default("REPORTED") // REPORTED, UNDER_REVIEW, RESOLVED, ESCALATED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student             Student              @relation(fields: [studentId], references: [id])
  reporter            User                 @relation("IncidentsReported", fields: [reportedBy], references: [id])
  disciplinaryActions DisciplinaryAction[]

  @@map("incidents")
}

model DisciplinaryAction {
  id                 String    @id @default(uuid())
  incidentId         String
  actionType         String    // WARNING, DETENTION, PARENT_MEETING, SUSPENSION, EXPULSION
  assignedBy         String
  description        String?
  startDate          DateTime?
  endDate            DateTime?
  parentNotified     Boolean   @default(false)
  parentAcknowledged Boolean   @default(false)
  status             String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  assigner User     @relation("ActionsAssigned", fields: [assignedBy], references: [id])

  @@map("disciplinary_actions")
}

model RedFlag {
  id            String    @id @default(uuid())
  studentId     String
  reason        String
  triggeredAt   DateTime  @default(now())
  autoGenerated Boolean   @default(false)
  incidentIds   Json      @default("[]")
  status        String    @default("ACTIVE") // ACTIVE, RESOLVED
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@map("red_flags")
}

// === Bus Management ===

model Vehicle {
  id             String   @id @default(uuid())
  number         String   @unique
  type           String   @default("BUS") // BUS, VAN, OTHER
  capacity       Int
  driverName     String?
  driverPhone    String?
  conductorName  String?
  conductorPhone String?
  gpsDeviceId    String?
  isActive       Boolean  @default(true)
  schoolId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school School  @relation(fields: [schoolId], references: [id])
  routes Route[]

  @@map("vehicles")
}

model Route {
  id          String   @id @default(uuid())
  name        String
  description String?
  vehicleId   String?
  schoolId    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school         School          @relation(fields: [schoolId], references: [id])
  vehicle        Vehicle?        @relation(fields: [vehicleId], references: [id])
  stops          Stop[]
  busAssignments BusAssignment[]
  boardingLogs   BoardingLog[]

  @@map("routes")
