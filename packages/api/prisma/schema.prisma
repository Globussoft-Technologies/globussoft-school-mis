  approvedBy  String?
  paidAt      DateTime?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, month, year])
  @@map("payroll_records")
}

model SalaryStructure {
  id          String   @id @default(uuid())
  role        String
  basicSalary Float
  hra         Float    @default(0)
  da          Float    @default(0)
  ta          Float    @default(0)
  pf          Float    @default(0)
  tax         Float    @default(0)
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([role, schoolId])
  @@map("salary_structures")
}

// ─── Diary ───────────────────────────────────────────────────────

model DiaryEntry {
  id          String   @id @default(uuid())
  studentId   String?
  classId     String?
  sectionId   String?
  date        DateTime @db.Date
  type        String   // HOMEWORK, CLASSWORK, NOTE, REMINDER, CIRCULAR
  subject     String?
  content     String   @db.Text
  createdBy   String   // teacher userId
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([classId, date])
  @@map("diary_entries")
}

// ─── Events ───────────────────────────────────────────────────────

model SchoolEvent {
  id              String    @id @default(uuid())
  title           String
  description     String?   @db.Text
  type            String    // SPORTS_DAY, ANNUAL_DAY, CULTURAL, WORKSHOP, COMPETITION, TRIP, CELEBRATION, OTHER
  startDate       DateTime
  endDate         DateTime?
  venue           String?
  organizer       String?
  budget          Float?
  status          String    @default("PLANNED") // PLANNED, APPROVED, ONGOING, COMPLETED, CANCELLED
  maxParticipants Int?
  schoolId        String
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  registrations EventRegistration[]

  @@map("school_events")
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  userId    String   // student or teacher
  role      String   @default("PARTICIPANT") // PARTICIPANT, VOLUNTEER, COORDINATOR, JUDGE
  status    String   @default("REGISTERED")  // REGISTERED, CONFIRMED, CANCELLED, ATTENDED
  createdAt DateTime @default(now())

  event SchoolEvent @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
  @@map("event_registrations")
}

// ─── Grievances ───────────────────────────────────────────────────

model Grievance {
  id           String    @id @default(uuid())
  ticketNumber String    @unique
  submittedBy  String    // userId
  category     String    // ACADEMIC, ADMINISTRATIVE, INFRASTRUCTURE, BULLYING, FEE, TRANSPORT, HOSTEL, OTHER
  subject      String
  description  String    @db.Text
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status       String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED, REOPENED
  assignedTo   String?
  resolution   String?   @db.Text
  resolvedAt   DateTime?
  closedAt     DateTime?
  schoolId     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("grievances")
}

// ─── ID Cards ─────────────────────────────────────────────────────

model IdCard {
  id          String   @id @default(uuid())
  userId      String
  cardNumber  String   @unique
  type        String   // STUDENT, TEACHER, STAFF
  validFrom   DateTime @db.Date
  validTo     DateTime @db.Date
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED, LOST
  photoUrl    String?
  printedAt   DateTime?
  createdAt   DateTime @default(now())

  @@map("id_cards")
}

// ─── Message Log ──────────────────────────────────────────────────

model MessageLog {
  id            String    @id @default(uuid())
  type          String    // SMS, EMAIL, WHATSAPP, PUSH
  recipient     String    // phone/email
  recipientName String?
  subject       String?
  content       String    @db.Text
  status        String    @default("QUEUED") // QUEUED, SENT, DELIVERED, FAILED, BOUNCED
  provider      String?   // MSG91, TEXTLOCAL, SMTP, etc.
  providerRef   String?   // external message ID
  sentAt        DateTime?
  deliveredAt   DateTime?
  failReason    String?
  metadata      Json?
  createdAt     DateTime  @default(now())

  @@index([type, status])
  @@index([recipient])
  @@map("message_logs")
}

// ─── Expenses ─────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(uuid())
  title       String
  category    String   // SALARY, MAINTENANCE, UTILITIES, SUPPLIES, TRANSPORT, EVENTS, INFRASTRUCTURE, OTHER
  amount      Float
  date        DateTime @db.Date
  vendor      String?
  invoiceNo   String?
  description String?  @db.Text
  status      String   @default("PENDING") // PENDING, APPROVED, PAID, REJECTED
  approvedBy  String?
  paidBy      String?
  receiptUrl  String?
  schoolId    String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

model Budget {
  id          String   @id @default(uuid())
  category    String
  amount      Float
  spent       Float    @default(0)
  month       Int?
  year        Int
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, month, year, schoolId])
  @@map("budgets")
}

// ─── Staff Directory ──────────────────────────────────────────────

model StaffProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  employeeId       String    @unique
  department       String    // ACADEMIC, ADMINISTRATION, ACCOUNTS, TRANSPORT, LIBRARY, IT, SPORTS, OTHER
  designation      String
  dateOfJoining    DateTime  @db.Date
  qualification    String?
  specialization   String?
  experience       Int?      // years
  emergencyContact String?
  emergencyPhone   String?
  address          String?   @db.Text
  bankAccount      String?
  panNumber        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("staff_profiles")
}

// ─── Gallery ──────────────────────────────────────────────────────

model GalleryAlbum {
  id          String    @id @default(uuid())
  title       String
  description String?
  coverUrl    String?
  eventDate   DateTime? @db.Date
  category    String    // EVENTS, SPORTS, ACADEMICS, CULTURAL, TRIPS, INFRASTRUCTURE, OTHER
  isPublished Boolean   @default(false)
  createdBy   String
  schoolId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  photos GalleryPhoto[]

  @@map("gallery_albums")
}

model GalleryPhoto {
  id        String   @id @default(uuid())
  albumId   String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("gallery_photos")
}

// ─── Alumni ───────────────────────────────────────────────────────

model Alumni {
  id              String   @id @default(uuid())
  name            String
  email           String?
  phone           String?
  graduationYear  Int
  lastClass       String
  currentStatus   String?  // HIGHER_EDUCATION, EMPLOYED, ENTREPRENEUR, OTHER
  organization    String?
  designation     String?
  city            String?
  linkedinUrl     String?
  achievements    String?  @db.Text
  photoUrl        String?
  isVerified      Boolean  @default(false)
  schoolId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("alumni")
}

// ─── Academic Year Transition ─────────────────────────────────────

model AcademicTransition {
  id               String    @id @default(uuid())
  fromSessionId    String
  toSessionId      String
  status           String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, ROLLED_BACK
  startedBy        String
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  studentsPromoted Int       @default(0)
  studentsRetained Int       @default(0)
  sectionsCreated  Int       @default(0)
  errors           Json      @default("[]")
  schoolId         String

  @@unique([fromSessionId, toSessionId])
  @@map("academic_transitions")
}

// ─── Phase 20 — Surveys ───────────────────────────────────────────

model Survey {
  id             String    @id @default(uuid())
  title          String
  description    String?   @db.Text
  type           String    // PARENT_SATISFACTION, TEACHER_EVALUATION, FACILITY_REVIEW, EVENT_FEEDBACK, CUSTOM
  status         String    @default("DRAFT") // DRAFT, ACTIVE, CLOSED
  startDate      DateTime? @db.Date
  endDate        DateTime? @db.Date
  targetAudience String    @default("ALL") // ALL, PARENTS, TEACHERS, STUDENTS
  createdBy      String
  schoolId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@map("surveys")
}

model SurveyQuestion {
  id         String  @id @default(uuid())
  surveyId   String
  text       String
  type       String  // RATING, TEXT, MULTIPLE_CHOICE, YES_NO
  options    Json?   // for MULTIPLE_CHOICE
  orderIndex Int
  isRequired Boolean @default(true)

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("survey_questions")
}

model SurveyResponse {
  id           String   @id @default(uuid())
  surveyId     String
  respondentId String   // userId
  answers      Json     // [{questionId, answer}]
  submittedAt  DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id])

  @@unique([surveyId, respondentId])
  @@map("survey_responses")
}

// ─── LMS Feature 1: Course Modules ────────────────────────────────────────────

model CourseModule {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  classId       String
  subjectId     String
  orderIndex    Int
  isPublished   Boolean  @default(false)
  unlockType    String   @default("ALWAYS") // ALWAYS, SEQUENTIAL, DATE, PREREQUISITE
  unlockDate    DateTime?
  prerequisiteModuleId String?
  completionCriteria String @default("VIEW_ALL") // VIEW_ALL, SCORE_MINIMUM, MANUAL
  minimumScore  Float?
  estimatedMinutes Int?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items CourseModuleItem[]

  @@map("course_modules")
}

model CourseModuleItem {
  id          String   @id @default(uuid())
  moduleId    String
  title       String
  type        String   // CONTENT, ASSIGNMENT, QUIZ, DISCUSSION, VIDEO, DOCUMENT, LINK, PAGE
  contentId   String?
  contentUrl  String?
  description String?  @db.Text
  orderIndex  Int
  isRequired  Boolean  @default(true)
  estimatedMinutes Int?
  createdAt   DateTime @default(now())

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completions ModuleItemCompletion[]

  @@map("course_module_items")
}

model ModuleItemCompletion {
  id          String   @id @default(uuid())
  itemId      String
  studentId   String
  status      String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  score       Float?
  completedAt DateTime?
  timeSpent   Int?
  createdAt   DateTime @default(now())

  item CourseModuleItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, studentId])
  @@map("module_item_completions")
}

// ─── LMS Feature 2: Discussion Forums ─────────────────────────────────────────

model DiscussionForum {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  classId     String
  subjectId   String?
  type        String   @default("OPEN") // OPEN, GRADED, Q_AND_A, ANNOUNCEMENT
  isLocked    Boolean  @default(false)
  isPinned    Boolean  @default(false)
  allowAnonymous Boolean @default(false)
  totalPoints Float?
  dueDate     DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts DiscussionPost[]

  @@map("discussion_forums")
}

model DiscussionPost {
  id        String   @id @default(uuid())
  forumId   String
  authorId  String
  parentId  String?
  content   String   @db.Text
  isAnonymous Boolean @default(false)
  isPinned  Boolean  @default(false)
  likes     Int      @default(0)
  score     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forum   DiscussionForum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  replies DiscussionPost[] @relation("PostReplies")
  parent  DiscussionPost?  @relation("PostReplies", fields: [parentId], references: [id])

  @@map("discussion_posts")
}

// ─── LMS Feature 3: Gamification ──────────────────────────────────────────────

model Badge {
  id          String   @id @default(uuid())
  name        String
  description String?
  iconUrl     String?
  category    String   // ACADEMIC, ATTENDANCE, PARTICIPATION, SPORTS, CONDUCT, CUSTOM
  criteria    String?  @db.Text
  pointsValue Int      @default(0)
  schoolId    String
  createdAt   DateTime @default(now())

  awards BadgeAward[]

  @@map("badges")
}

model BadgeAward {
  id        String   @id @default(uuid())
  badgeId   String
  studentId String
  awardedBy String?
  reason    String?
  awardedAt DateTime @default(now())

  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([badgeId, studentId])
  @@map("badge_awards")
}

model StudentPoints {
  id          String   @id @default(uuid())
  studentId   String
  points      Int      @default(0)
  level       Int      @default(1)
  category    String   // ACADEMIC, ATTENDANCE, PARTICIPATION, HOMEWORK, QUIZ, EXTRA_CREDIT
  reason      String?
  awardedBy   String?
  createdAt   DateTime @default(now())

  @@map("student_points")
}

model Leaderboard {
  id          String   @id @default(uuid())
  studentId   String
  classId     String
  totalPoints Int      @default(0)
  level       Int      @default(1)
  rank        Int?
  badgeCount  Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([studentId, classId])
  @@map("leaderboards")
}

// ─── Phase 22 — LMS Deep Features ────────────────────────────────

// Learning Paths & Playlists
model LearningPath {
  id             String   @id @default(uuid())
  title          String
  description    String?  @db.Text
  subjectId      String?
  classId        String?
  difficulty     String   @default("MEDIUM") // BEGINNER, MEDIUM, ADVANCED
  estimatedHours Float?
  isPublished    Boolean  @default(false)
  createdBy      String
  schoolId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps       LearningPathStep[]
  enrollments LearningPathEnrollment[]

  @@map("learning_paths")
}

model LearningPathStep {
  id               String  @id @default(uuid())
  pathId           String
  title            String
  type             String  // CONTENT, QUIZ, ASSIGNMENT, VIDEO, READING, ACTIVITY
  resourceId       String?
  resourceUrl      String?
  description      String? @db.Text
  orderIndex       Int
  isOptional       Boolean @default(false)
  estimatedMinutes Int?

  path LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@map("learning_path_steps")
}

model LearningPathEnrollment {
  id             String    @id @default(uuid())
  pathId         String
  studentId      String
  currentStep    Int       @default(0)
  completedSteps Int       @default(0)
  totalSteps     Int       @default(0)
  status         String    @default("ENROLLED") // ENROLLED, IN_PROGRESS, COMPLETED, DROPPED
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  lastAccessedAt DateTime?

  path LearningPath @relation(fields: [pathId], references: [id])

  @@unique([pathId, studentId])
  @@map("learning_path_enrollments")
}

// Rubrics System
model Rubric {
  id          String   @id @default(uuid())
  title       String
  description String?
  subjectId   String?
  type        String   @default("POINTS") // POINTS, PERCENTAGE, PROFICIENCY
  maxScore    Float?
  createdBy   String
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  criteria RubricCriterion[]

  @@map("rubrics")
}

model RubricCriterion {
  id          String  @id @default(uuid())
  rubricId    String
  title       String
  description String?
  maxPoints   Float
  orderIndex  Int

  rubric Rubric        @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  levels RubricLevel[]

  @@map("rubric_criteria")
}

model RubricLevel {
  id          String  @id @default(uuid())
  criterionId String
  title       String
  description String? @db.Text
  points      Float
  orderIndex  Int

  criterion RubricCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@map("rubric_levels")
}

model RubricAssessment {
  id           String   @id @default(uuid())
  rubricId     String
  studentId    String
  assessmentId String?
  assignmentId String?
  scores       Json     // [{criterionId, levelId, points, comment}]
  totalScore   Float?
  feedback     String?  @db.Text
  assessedBy   String
  createdAt    DateTime @default(now())

  @@map("rubric_assessments")
}

// Live Classes
model LiveClass {
  id              String    @id @default(uuid())
  title           String
  description     String?
  classId         String
  subjectId       String?
  teacherId       String
  scheduledAt     DateTime
  duration        Int
  meetingUrl      String?
  recordingUrl    String?
  status          String    @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED, CANCELLED
  maxParticipants Int?
  attendeeCount   Int       @default(0)
  notes           String?   @db.Text
  schoolId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attendees LiveClassAttendance[]

  @@map("live_classes")
}

model LiveClassAttendance {
  id          String    @id @default(uuid())
  liveClassId String
  studentId   String
  joinedAt    DateTime?
  leftAt      DateTime?
  duration    Int?

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, studentId])
  @@map("live_class_attendances")
}
